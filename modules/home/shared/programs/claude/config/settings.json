{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.log/claude && jq -r '[\"[\", (now | strftime(\"%Y-%m-%dT%H:%M:%SZ\")), \"] \", .tool_name, \": \", (.tool_input | tostring)] | join(\"\")' >> ~/.log/claude/tool-calls.log 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.p8)",
      "Read(**/*.pfx)",
      "Read(**/.gcp/**)",
      "Read(**/.azure/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/secrets/**)",
      "Read(./.config/sops/**)",
      "Read(./.config/sops-nix/**)",
      "Bash(rm -rf /:*)"
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  }
}
