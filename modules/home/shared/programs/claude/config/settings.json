{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context/session-start.py"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/skills/skill-eval.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/direnv/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context/stop-context-guard.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/context/pre-compact.py"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skills/skill-eval.sh"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "**/.envrc",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/direnv/reload.sh"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/direnv/reload.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/emacs/emacs-buffer-context.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skills/skill-remind.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/context/explore-remind.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(~/.claude/**)",
      "Read(~/nix/**)",
      "Bash(git -C ~/nix*)",
      "Read(~/.emacs.d/**)",
      "mcp__emacs-tools__*"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.p8)",
      "Read(**/*.pfx)",
      "Read(**/.gcp/**)",
      "Read(**/.azure/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/secrets/**)",
      "Read(~/.config/sops/**)",
      "Read(~/.config/sops-nix/**)",
      "Bash(rm -rf /:*)",
      "Bash(git commit*)"
    ]
  },
  "skillOverrides": {
    "review": "off"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/hooks/caveman/caveman-statusline.sh"
  }
}
