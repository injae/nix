{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-eval.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tool-call-log.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(/Users/nieel/nix/**)",
      "Edit(/Users/nieel/nix/**)",
      "Write(/Users/nieel/nix/**)",
      "Bash(git -C /Users/nieel/nix*)",
      "Read(/Users/nieel/.emacs.d/**)",
      "mcp__emacs-tools__*"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.p8)",
      "Read(**/*.pfx)",
      "Read(**/.gcp/**)",
      "Read(**/.azure/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/secrets/**)",
      "Read(./.config/sops/**)",
      "Read(./.config/sops-nix/**)",
      "Bash(rm -rf /:*)"
    ]
  },
  "skillOverrides": {
    "review": "off"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  }
}
